# ════════════════════════════════════════════════════════════════════════════════
# Polymarket BTC 5-Min Bot — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ── Polymarket CLOB ──────────────────────────────────────────────────────────
# Generated via: polymarket-cli or create_or_derive_api_creds()
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here
POLYMARKET_API_PASSPHRASE=your_polymarket_passphrase_here
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com

# ── Wallet ───────────────────────────────────────────────────────────────────
# NEVER commit your real private key.
# Generate a DEDICATED trading wallet — never use your main wallet.
# Fund it with only the capital you intend to risk.
WALLET_PRIVATE_KEY=0x_your_64_char_hex_private_key_here
WALLET_ADDRESS=0x_your_wallet_address_here

# ── Coinbase Developer Platform (CDP) / AgentKit ─────────────────────────────
# Create at: https://portal.cdp.coinbase.com/
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
CDP_WALLET_SECRET=your_cdp_wallet_secret

# ── Blockchain RPC Endpoints ─────────────────────────────────────────────────
# Polygon mainnet (REQUIRED — chain_id=137 for Polymarket order signing)
# Get a free key at: https://www.alchemy.com/
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# Base mainnet (optional — for AgentKit gasless USDC funding flow)
BASE_RPC_URL=https://mainnet.base.org

# Ethereum mainnet (optional — for bridging USDC to Polygon)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram, get token + your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_numeric_chat_id
# Admin user ID for full control (write actions). If unset, uses TELEGRAM_CHAT_ID.
TELEGRAM_ADMIN_ID=

# ── Claude / Anthropic API ───────────────────────────────────────────────────
# Required if using AI-assisted market commentary features
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Market Data APIs ──────────────────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com
BTC_SYMBOL=BTC/USDT
CANDLE_INTERVAL=1m

# Coinbase Exchange (public, no key, used as primary BTC price source)
COINBASE_EXCHANGE_URL=https://api.exchange.coinbase.com

# CoinGecko (optional — for fallback BTC chart data)
COINGECKO_BASE_URL=https://api.coingecko.com
COINGECKO_API_KEY=your_coingecko_demo_key_here  # optional, increases rate limits

# ── Trading Parameters ───────────────────────────────────────────────────────
# Maximum fraction of portfolio to lose in a single day before kill switch
MAX_DAILY_DRAWDOWN_PCT=0.05

# Fractional Kelly multiplier (0.25 = quarter-Kelly, recommended for safety)
KELLY_FRACTION=0.25

# Minimum edge (model_prob - market_price) required to place a trade
MIN_EDGE_THRESHOLD=0.03

# Maximum bid-ask spread to tolerate before skipping a market
MAX_SPREAD=0.04

# GARCH volatility regime filter: skip trades when vol > this percentile
GARCH_REGIME_PERCENTILE=0.65

# Hard cap: maximum USDC per single trade
MAX_POSITION_USDC=50.0

# Set to true for paper trading (no real orders), false for live execution
PAPER_TRADING=true
# Or use MODE=paper|live (paper is default)
MODE=paper

# ── Market Discovery ─────────────────────────────────────────────────────────
# Path to JSON file containing discovered BTC 5-min market token IDs
# Generated by: python scripts/find_btc_markets.py
BTC_MARKETS_CONFIG=config/btc_markets.json

# ── Web Dashboard ─────────────────────────────────────────────────────────────
WEB_PORT=8080
WEBUI_PORT=8787
LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════════════════════════
# Provider Selection
# ════════════════════════════════════════════════════════════════════════════════

# Wallet backend:
#   sdk     — py-clob-client + coinbase-agentkit SDK (default, no extra setup)
#   agentic — Coinbase Agentic Wallets via awal CLI (run scripts/awal_bootstrap.py first)
#   none    — paper trading only, no wallet
WALLET_PROVIDER=sdk

# Execution backend:
#   clob    — py-clob-client CLOB API (default)
#   cli     — subprocess CLI (requires POLYMARKET_CLI_CMD)
EXECUTION_PROVIDER=clob

# ════════════════════════════════════════════════════════════════════════════════
# Coinbase Agentic Wallet (awal CLI)
# Only needed when WALLET_PROVIDER=agentic
# Bootstrap with: python scripts/awal_bootstrap.py
# ════════════════════════════════════════════════════════════════════════════════

# Where awal stores its auth session token (NEVER commit this file)
AWAL_SESSION_FILE=~/.polyquant/awal_session.json

# CLI binary (e.g. awal, npx awal@latest)
AWAL_BIN=awal

# Timeout in seconds for each awal CLI subprocess call (default: 30)
AWAL_CMD_TIMEOUT=30

# ════════════════════════════════════════════════════════════════════════════════
# Polymarket CLI Execution Provider
# Only needed when EXECUTION_PROVIDER=cli
# ════════════════════════════════════════════════════════════════════════════════

# Polymarket CLI (optional; for EXECUTION_PROVIDER=cli or verification)
POLYMARKET_CLI_CMD=
POLYMARKET_CLI_PATH=

# ════════════════════════════════════════════════════════════════════════════════
# Audit Log
# ════════════════════════════════════════════════════════════════════════════════

# Append-only JSONL trade blotter (relative to project root or absolute)
AUDIT_LOG_PATH=paper_trading/audit.log
