#!/usr/bin/env bash
# ════════════════════════════════════════════════════════════════════════════
# polyquant — management CLI for the PolyQuant trading bot
#
# Usage:
#   ./polyquant <command> [options]
#
# Commands:
#   up        Build image (if needed) and start the bot in the background
#   down      Stop and remove the running container
#   restart   Stop then start
#   build     Rebuild the Docker image from scratch (--no-cache)
#   logs      Tail live logs (Ctrl+C to stop)
#   status    Show container health and uptime
#   doctor    Validate .env, Docker, and project setup
#   shell     Open a bash shell inside the running container
#   ps        Show running containers
# ════════════════════════════════════════════════════════════════════════════

set -euo pipefail

COMPOSE_FILE="$(cd "$(dirname "$0")" && pwd)/docker-compose.yml"
SERVICE="polyquant"

# ── Helpers ──────────────────────────────────────────────────────────────────

log()  { printf '\033[1;34m[polyquant]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m  ✓\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m  !\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m  ✗\033[0m %s\n' "$*"; }
die()  { fail "$*"; exit 1; }

require_docker() {
    docker info >/dev/null 2>&1 || die "Docker daemon is not running. Start Docker and try again."
    docker compose version >/dev/null 2>&1 || die "docker compose (v2) not found. Install Docker Desktop or the compose plugin."
}

require_env() {
    [[ -f "$(dirname "$COMPOSE_FILE")/.env" ]] \
        || die ".env not found. Copy .env.example → .env and fill in your values."
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_up() {
    require_docker; require_env
    log "Starting $SERVICE …"
    docker compose -f "$COMPOSE_FILE" up -d --build "$SERVICE"
    ok "$SERVICE is up. Run './polyquant logs' to follow output."
}

cmd_down() {
    require_docker
    log "Stopping $SERVICE …"
    docker compose -f "$COMPOSE_FILE" down "$SERVICE"
    ok "$SERVICE stopped."
}

cmd_restart() {
    cmd_down
    cmd_up
}

cmd_build() {
    require_docker
    log "Rebuilding image (no cache) …"
    docker compose -f "$COMPOSE_FILE" build --no-cache "$SERVICE"
    ok "Image rebuilt."
}

cmd_logs() {
    require_docker
    log "Tailing logs (Ctrl+C to stop) …"
    docker compose -f "$COMPOSE_FILE" logs -f --tail=100 "$SERVICE"
}

cmd_status() {
    require_docker
    log "Container status:"
    docker compose -f "$COMPOSE_FILE" ps "$SERVICE"
    echo
    CID=$(docker compose -f "$COMPOSE_FILE" ps -q "$SERVICE" 2>/dev/null || true)
    if [[ -n "$CID" ]]; then
        log "Health:"
        docker inspect --format='  State:   {{.State.Status}}
  Health:  {{if .State.Health}}{{.State.Health.Status}}{{else}}(no healthcheck){{end}}
  Started: {{.State.StartedAt}}' "$CID" 2>/dev/null || true
    fi
}

cmd_doctor() {
    log "Running pre-flight checks …"
    local ok=true

    # Docker
    if docker info >/dev/null 2>&1; then
        ok "Docker daemon is running"
    else
        fail "Docker daemon is not running"; ok=false
    fi

    if docker compose version >/dev/null 2>&1; then
        ok "docker compose (v2) found"
    else
        fail "docker compose v2 not found"; ok=false
    fi

    # .env
    local project_dir; project_dir="$(dirname "$COMPOSE_FILE")"
    if [[ -f "$project_dir/.env" ]]; then
        ok ".env file found"
    else
        fail ".env not found — copy from .env.example"; ok=false
    fi

    # Required env vars
    local required_vars=(TELEGRAM_BOT_TOKEN TELEGRAM_CHAT_ID)
    for var in "${required_vars[@]}"; do
        val=$(grep -E "^${var}=" "$project_dir/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
        if [[ -n "$val" && "$val" != *"your_"* && "$val" != *"_here"* ]]; then
            ok "$var is set"
        else
            fail "$var is missing or still a placeholder"; ok=false
        fi
    done

    # Optional but important
    local optional_vars=(ANTHROPIC_API_KEY POLYMARKET_API_KEY WALLET_PRIVATE_KEY)
    for var in "${optional_vars[@]}"; do
        val=$(grep -E "^${var}=" "$project_dir/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
        if [[ -n "$val" && "$val" != *"your_"* && "$val" != *"_here"* ]]; then
            ok "$var is set (optional)"
        else
            warn "$var is not set (optional — paper trading will still work)"
        fi
    done

    # Port check
    if command -v lsof >/dev/null 2>&1; then
        local port="${WEB_PORT:-8080}"
        if lsof -i :"$port" >/dev/null 2>&1; then
            warn "Port $port is already in use — set WEB_PORT in .env to avoid conflict"
        else
            ok "Port $port is available"
        fi
    fi

    echo
    if $ok; then
        ok "All checks passed — ready to run './polyquant up'"
    else
        fail "Some checks failed — fix the issues above before starting"
        return 1
    fi
}

cmd_shell() {
    require_docker
    CID=$(docker compose -f "$COMPOSE_FILE" ps -q "$SERVICE" 2>/dev/null || true)
    [[ -n "$CID" ]] || die "$SERVICE is not running. Start it with './polyquant up' first."
    log "Opening shell in $SERVICE …"
    docker exec -it "$CID" /bin/bash
}

cmd_ps() {
    require_docker
    docker compose -f "$COMPOSE_FILE" ps
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
Usage: ./polyquant <command>

Commands:
  up        Build and start the bot (background)
  down      Stop the bot
  restart   Stop then start
  build     Rebuild Docker image (--no-cache)
  logs      Tail live container logs
  status    Show container state and health
  doctor    Validate environment and Docker setup
  shell     Open bash shell inside the running container
  ps        Show all compose services
EOF
}

case "${1:-}" in
    up)       cmd_up ;;
    down)     cmd_down ;;
    restart)  cmd_restart ;;
    build)    cmd_build ;;
    logs)     cmd_logs ;;
    status)   cmd_status ;;
    doctor)   cmd_doctor ;;
    shell)    cmd_shell ;;
    ps)       cmd_ps ;;
    *)        usage; [[ -z "${1:-}" ]] || die "Unknown command: $1" ;;
esac
